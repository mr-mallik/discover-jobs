# Job Scraper Configuration Template
# Copy this file to .env and configure with your settings

# Job search keywords (Python list format)
KEY_WRDS=["Software Engineer", "Data Scientist", "Product Manager", "UX Designer", "DevOps Engineer"]

# Job search location (e.g., "New York, NY" or "Remote")
LOCATION=["Manchester", "London", "Leeds"]

# SMTP Email Configuration (for sending job notifications)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USERNAME=hello@cosmokode.com
SMTP_PASSWORD=your-password-here
SMTP_ENCRYPTION=ssl

# Email recipient for job notifications
SMTP_RECIPIENT=your-email@example.com